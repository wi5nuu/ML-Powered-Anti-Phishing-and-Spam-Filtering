# ═══════════════════════════════════════════════════════════════════════════
# CogniMail — Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════
# Copy this file to .env and adjust values for your environment.
#   cp .env.example .env
# ═══════════════════════════════════════════════════════════════════════════

# ── Environment ──────────────────────────────────────────────────────────
ENVIRONMENT=development          # development | production | testing
DEBUG=true                       # Enable debug logging
LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR
APP_TIMEZONE=Asia/Jakarta        # Timezone for the application

# ── Security (CRITICAL: Change these in production!) ────────────────────
# Generate a strong key: python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET=super-secret-key-change-in-production
DASHBOARD_SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480   # 8 hours

# ── Seed Credentials (Change immediately after first login!) ──────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme
SUPERADMIN_USERNAME=superadmin
SUPERADMIN_PASSWORD=superadmin123

# ── Database ────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./cognimail.db
# For production PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/cognimail
DB_URL=sqlite:///./cognimail.db
DB_SYNC_URL=sqlite:///./cognimail.db
DB_ASYNC_URL=sqlite+aiosqlite:///./cognimail.db
DASHBOARD_DB_URL=

# ── Redis ────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_QUEUE_NAME=email_pipeline
PUBSUB_CHANNEL=email:processed

# ── CORS ─────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:8000
# For production:
# CORS_ORIGINS=https://cognimail.yourdomain.com

# ── Rate Limiting ────────────────────────────────────────────────────────
RATE_LIMIT=30/minute
ADMIN_RATE_LIMIT=60/minute

# ── SMTP (Outbound Email) ────────────────────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=

# ── IMAP (Inbound Email) ────────────────────────────────────────────────
IMAP_HOST=localhost
IMAP_PORT=993

# ── SpamAssassin ─────────────────────────────────────────────────────────
SPAMASSASSIN_HOST=localhost
SPAMASSASSIN_PORT=783

# ── ML / Model ──────────────────────────────────────────────────────────
MODEL_DIR=classifier/models
AUTO_RETRAIN_INTERVAL_HOURS=168    # Retrain model every 7 days
ANOMALY_THRESHOLD=0.7              # Anomaly detection threshold (0-1)
CONFIDENCE_THRESHOLD=0.5           # Classification confidence threshold

# ── Email Retention ──────────────────────────────────────────────────────
MAX_QUARANTINE_DAYS=30             # Auto-purge quarantined emails after N days
MAX_ATTACHMENT_BYTES=10485760      # Max attachment size (10 MB)
MAX_STORED_ATTACHMENTS=20          # Max attachments to store per email

# ── Worker ────────────────────────────────────────────────────────────────
WORKER_CONCURRENCY=10              # Number of concurrent email processors
CLASSIFIER_URL=http://classifier:8001   # ML classifier service URL
