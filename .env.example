# ─── CogniMail Production Environment Template ─────────────────────────────────
# Copy this file to .env and fill in all values before deploying.
# NEVER commit .env to version control. It is already in .gitignore.
# ────────────────────────────────────────────────────────────────────────────────

# ── Runtime mode ────────────────────────────────────────────────────────────────
ENV=production

# ── Domain / TLS ────────────────────────────────────────────────────────────────
# Domain that serves the dashboard (Caddy will obtain a Let's Encrypt cert)
DASHBOARD_DOMAIN=mail.example.com
GRAFANA_DOMAIN=grafana.example.com
PROMETHEUS_DOMAIN=prometheus.example.com
# Email address used by Caddy to register Let's Encrypt certs
CADDY_TLS_EMAIL=admin@example.com
# Allowed hosts for the FastAPI TrustedHostMiddleware (comma-separated)
ALLOWED_HOSTS=mail.example.com,www.mail.example.com

# ── Dashboard security ──────────────────────────────────────────────────────────
# MUST be a 64-hex-char random string: python -c "import secrets; print(secrets.token_hex(32))"
DASHBOARD_SECRET_KEY=CHANGE_ME_generate_with_secrets_token_hex_32
# JWT token expiry in minutes (default 60)
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── CORS (comma-separated origins) ──────────────────────────────────────────────
CORS_ORIGINS=https://mail.example.com

# ── Database (PostgreSQL) ────────────────────────────────────────────────────────
POSTGRES_DB=cognimail
DB_USER=cogniuser
DB_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_PORT=5432
# Sync URL (used by dashboard / seed)
DB_SYNC_URL=postgresql+psycopg://cogniuser:CHANGE_ME_strong_db_password@postgres:5432/cognimail
# Async URL (used by worker / smtp_receiver)
WORKER_DB_URL=postgresql+asyncpg://cogniuser:CHANGE_ME_strong_db_password@postgres:5432/cognimail
DB_ASYNC_URL=postgresql+asyncpg://cogniuser:CHANGE_ME_strong_db_password@postgres:5432/cognimail

# ── Redis ────────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
REDIS_PORT=6379
REDIS_QUEUE_NAME=email_pipeline
PUBSUB_CHANNEL=email:processed

# ── Classifier service ───────────────────────────────────────────────────────────
CLASSIFIER_PORT=8001
CLASSIFIER_URL=http://classifier:8001

# ── SpamAssassin ─────────────────────────────────────────────────────────────────
SPAMASSASSIN_HOST=spamassassin
SPAMASSASSIN_PORT=783
SPAMASSASSIN_PUBLIC_PORT=783

# ── SMTP Receiver (inbound MX) ───────────────────────────────────────────────────
# Domain that receives email — must match your DNS MX record
SMTP_DOMAIN=mail.example.com
SMTP_HOST=0.0.0.0
SMTP_PORT=25
SMTP_SUBMISSION_PORT=587
# Comma-separated list of domains whose email this server will accept
ACCEPTED_MAIL_DOMAINS=example.com,mail.example.com
# Max inbound message size in bytes (default 25 MB)
MAX_MESSAGE_BYTES=26214400
# STARTTLS: set these to your TLS cert/key paths (e.g. Let's Encrypt)
# Mount the cert directory into smtp_receiver container via SMTP_TLS_CERT_DIR
SMTP_TLS_CERT_DIR=/etc/letsencrypt
SMTP_TLS_CERT=/certs/live/mail.example.com/fullchain.pem
SMTP_TLS_KEY=/certs/live/mail.example.com/privkey.pem
# Set to true to reject non-TLS connections (recommended for port 587)
SMTP_REQUIRE_TLS=false
# Max concurrent SMTP connections per IP (anti-abuse)
SMTP_MAX_CONN_PER_IP=10

# Outbound delivery: "direct" sends to recipient MX servers on port 25.
# Use "relay" when sending through an SMTP provider.
OUTBOUND_SMTP_MODE=direct
OUTBOUND_HELO_HOSTNAME=mail.example.com
FORWARDER_SMTP_HOST=
FORWARDER_SMTP_PORT=587
FORWARDER_SMTP_USER=
FORWARDER_SMTP_PASS=
# Leave empty for multi-mailbox sending; the active mailbox becomes the sender.
FORWARDER_FROM=
FORWARDER_STARTTLS=true

# ── Outbound SMTP (notifications / alerts) ──────────────────────────────────────
SMTP_USER=noreply@example.com
SMTP_PASSWORD=CHANGE_ME_smtp_password
SMTP_SERVER=smtp.example.com
SMTP_OUTBOUND_PORT=587
ALERT_RECIPIENT=admin@example.com

# ── Mail domain (shown in frontend) ─────────────────────────────────────────────
VITE_MAIL_DOMAIN=example.com

# ── Google OAuth (optional) ─────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://mail.example.com/auth/google/callback

# ── ML thresholds ───────────────────────────────────────────────────────────────
THRESHOLD_QUARANTINE=0.70
THRESHOLD_WARN=0.30
FUSION_ML_WEIGHT=0.50
FUSION_SA_WEIGHT=0.25
FUSION_ANOMALY_WEIGHT=0.25

# ── Quarantine cleanup ───────────────────────────────────────────────────────────
MAX_QUARANTINE_DAYS=30

# ── Seed users (default credentials — CHANGE in production) ─────────────────────
# Passwords must be at least 8 chars with uppercase, lowercase, digit, and symbol
SUPERADMIN_PASSWORD=CHANGE_ME_SuperAdmin@2025!
ADMIN_PASSWORD=CHANGE_ME_Admin@2025!
USER_PASSWORD=CHANGE_ME_User@2025!

# ── Monitoring (Grafana) ─────────────────────────────────────────────────────────
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=CHANGE_ME_grafana_password
