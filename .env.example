# Email Ingestion
IMAP_HOST=localhost
IMAP_PORT=1143
IMAP_USER=test@lti.local
IMAP_PASSWORD=changeme
IMAP_MAILBOX=INBOX
IMAP_POLL_INTERVAL=30

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_QUEUE_NAME=email_pipeline

# Database
DB_URL=sqlite+aiosqlite:///./lti_antiphishing.db
DB_PASSWORD=

# Classifier Service
CLASSIFIER_URL=http://localhost:8001
SPAMASSASSIN_HOST=localhost
SPAMASSASSIN_PORT=783

# Decision Engine Thresholds
THRESHOLD_CLEAN=0.30
THRESHOLD_WARN=0.70

# Unsupervised Anomaly Detection
ANOMALY_ISOLATION_FOREST_CONTAMINATION=0.05
ANOMALY_ONE_CLASS_SVM_NU=0.05
ANOMALY_QUARANTINE_THRESHOLD=0.90

# Fusion Weights (3-way)
FUSION_ML_WEIGHT=0.50
FUSION_SA_WEIGHT=0.25
FUSION_ANOMALY_WEIGHT=0.25

# Dashboard
DASHBOARD_SECRET_KEY=dev-secret-key-123
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# Prometheus
METRICS_ENABLED=true

# Alerting (optional)
SLACK_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
ALERT_SMTP_HOST=
ALERT_SMTP_PORT=587
ALERT_SMTP_USER=
ALERT_SMTP_PASSWORD=

# Security
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
