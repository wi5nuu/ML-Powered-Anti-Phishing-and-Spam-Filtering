# ═══════════════════════════════════════════════════════════════════════════
# CogniMail — .gitignore
# ═══════════════════════════════════════════════════════════════════════════

# ── Python ────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
*.egg
*.so
.python-version

# ── Virtual Environment ──────────────────────────────────────────────────
.venv/
venv/
env/
virtualenv/

# ── IDE / Editor ─────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-workspace
*.sublime-project

# ── Database ─────────────────────────────────────────────────────────────
*.db
*.db-journal
*.db-wal
*.db-shm

# ── Model Artifacts ──────────────────────────────────────────────────────
classifier/models/*_2026*.joblib
classifier/models/*_from_ham.joblib
classifier/models/metadata_*.json
classifier/models/*.joblib

# ── Datasets (large) ─────────────────────────────────────────────────────
data/dataset_*/
data/processed/*.csv
data/raw/enron/
data/raw/spamassassin_corpus/
data/raw/indonesian/
data/raw/*.tar.*
data/processed/large_*

# ── Logs ─────────────────────────────────────────────────────────────────
logs/
*.log

# ── Environment ──────────────────────────────────────────────────────────
.env
.env.local
.env.production

# ── Test / Coverage ──────────────────────────────────────────────────────
htmlcov/
.coverage
coverage.xml
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/

# ── Docker ───────────────────────────────────────────────────────────────
docker-compose.override.yml

# ── Frontend ─────────────────────────────────────────────────────────────
node_modules/
dashboard/frontend/node_modules/
dashboard/frontend/dist/
dashboard/static/dist/
frontend/node_modules/
frontend/dist/

# ── Temporary / Generated ────────────────────────────────────────────────
__pypackages__/
*.pyo
instance/
*.manifest
*.spec
.cache/
*.tmp

# ── OS ───────────────────────────────────────────────────────────────────
Thumbs.db
.DS_Store
Desktop.ini
*.bak

# ── Temporary Scripts (development only) ────────────────────────────────
_start_realtime.py
_retrain_unsupervised.py
_realtime_clean.py
_live_demo.py
_check_db.py
add_broadcasts.py
fix_css.py

